  "keyFeatures": [
    "Transport request workflow with approval system",
    "Mission lifecycle management (create, assign, execute, complete)",
    "Vehicle fleet management with external plate API integration",
    "Driver assignment and availability tracking",
    "Comprehensive catalog management for statuses and types",
    "Historical state tracking for requests and missions",
    "Multi-department support with role-based access",
    "Email notifications for request state changes",
    "Mileage and fuel consumption tracking"
  ],
  "publicApiSurface": [
    "POST /solicitud - Create transport request",
    "POST /solicitud/{id}/aprobar - Approve request",
    "POST /solicitud/{id}/rechazar - Reject request",
    "POST /solicitud/{id}/cancelar - Cancel request",
    "GET /solicitud/{id}/historico - Get request history",
    "POST /mision - Create mission",
    "POST /mision/{id}/asignar - Assign vehicle and driver",
    "POST /mision/{id}/iniciar - Start mission",
    "POST /mision/{id}/finalizar - Complete mission",
    "POST /mision/{id}/cancelar - Cancel mission",
    "POST /vehiculo - Create vehicle",
    "POST /vehiculo/crear-por-placa - Create vehicle from plate API",
    "GET /vehiculo/consulta-placa/{placa} - Query external plate API",
    "POST /motorista - Create driver",
    "GET /lugar - List locations",
    "GET /departamento - List departments",
    "GET /estado-solicitud - List request statuses",
    "GET /estado-mision - List mission statuses",
    "GET /clase-vehiculo - List vehicle classes",
    "GET /tipo-combustible - List fuel types"
  ]
}
